# Tim's Car Deals — Environment Variables
# Copy this to .env and fill in your values
# NEVER commit .env to version control

# ─── Required ────────────────────────────────────────────────────────────────

# Admin panel password (change this!)
ADMIN_PASSWORD=changeme_strong_password_here

# Session secret — generate with: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
SESSION_SECRET=generate_a_very_long_random_string_here_using_command_above

# ─── Optional ────────────────────────────────────────────────────────────────

# Port the app listens on (default: 3000)
PORT=3000
